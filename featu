**Step 3:** Create a PostGIS-enabled geographic proximity function:

```sql
CREATE OR REPLACE FUNCTION find_nearby_donors(
  req_lat FLOAT,
  req_lng FLOAT,
  radius_km INTEGER,
  req_blood_group TEXT
) RETURNS TABLE(donor_id UUID, distance_km FLOAT) AS $$
  SELECT 
    p.id as donor_id,
    (6371 * acos(
      cos(radians(req_lat)) * cos(radians((p.location->>'lat')::FLOAT)) *
      cos(radians((p.location->>'lng')::FLOAT) - radians(req_lng)) +
      sin(radians(req_lat)) * sin(radians((p.location->>'lat')::FLOAT))
    )) AS distance_km
  FROM profiles p
  WHERE 
    p.role = 'donor'
    AND p.availability_status = 'available'
    AND p.blood_group = ANY(get_compatible_blood_groups(req_blood_group))
    AND p.cooldown_ends_at IS NULL OR p.cooldown_ends_at < NOW()
    AND (p.location->>'lat') IS NOT NULL
  HAVING distance_km <= radius_km
  ORDER BY distance_km;
$$ LANGUAGE SQL;
```

**Step 4:** Create blood group compatibility function:

```sql
CREATE OR REPLACE FUNCTION get_compatible_blood_groups(needed TEXT)
RETURNS TEXT[] AS $$
BEGIN
  RETURN CASE needed
    WHEN 'A+' THEN ARRAY['A+', 'A-', 'O+', 'O-']
    WHEN 'A-' THEN ARRAY['A-', 'O-']
    WHEN 'B+' THEN ARRAY['B+', 'B-', 'O+', 'O-']
    WHEN 'B-' THEN ARRAY['B-', 'O-']
    WHEN 'AB+' THEN ARRAY['A+','A-','B+','B-','AB+','AB-','O+','O-']
    WHEN 'AB-' THEN ARRAY['A-','B-','AB-','O-']
    WHEN 'O+' THEN ARRAY['O+', 'O-']
    WHEN 'O-' THEN ARRAY['O-']
    ELSE ARRAY[needed]
  END;
END;
$$ LANGUAGE plpgsql;
```

